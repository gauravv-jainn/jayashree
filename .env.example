# ============================================================================
# Environment Variables Template for Jayashree Foundation
# ============================================================================
#
# IMPORTANT: DO NOT commit the .env file to version control!
# Copy this file to .env and fill in your actual values.
# The .env file is listed in .gitignore to prevent accidental commits.
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values in the .env file
#   3. Keep this file (.env.example) in version control as reference
#
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Node environment (development, production, staging)
NODE_ENV=development

# Application port
PORT=3000

# Application host
HOST=localhost

# Base URL for the application
VITE_API_URL=http://localhost:3000

# Public contact email (available in frontend via import.meta.env)
VITE_CONTACT_EMAIL=emailisunknown13@gmail.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database connection string (if using database)
# Example: mongodb://username:password@localhost:27017/jayashree_foundation
DATABASE_URL=

# Database name
DB_NAME=jayashree_foundation

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT secret key for token generation (generate a strong random key)
# Minimum 32 characters recommended
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiration time (e.g., 7d, 24h, 30d)
JWT_EXPIRY=7d

# Password hashing salt rounds (bcryptjs)
SALT_ROUNDS=10

# Admin credentials (for initial setup)
ADMIN_EMAIL=admin@jayashreefoundation.org
ADMIN_PASSWORD=change_this_secure_password

# ============================================================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================================================

# Email service provider (gmail, outlook, custom SMTP, etc.)
EMAIL_SERVICE=gmail

# Email account/sender address
EMAIL_USER=your_email@gmail.com

# Email password or app-specific password
# For Gmail: Use App Password (not your regular password)
EMAIL_PASSWORD=your_app_specific_password

# SMTP server (if not using a service provider)
SMTP_HOST=smtp.gmail.com

# SMTP port (typically 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Enable TLS for SMTP
SMTP_TLS=true

# Email recipient for contact form submissions
CONTACT_EMAIL=info.jayashreefoundation@gmail.com

# ============================================================================
# FILE UPLOAD & STORAGE
# ============================================================================

# Maximum file upload size (in bytes)
MAX_FILE_SIZE=5242880

# Allowed file types for uploads (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Upload directory path
UPLOAD_DIR=./uploads

# Base URL for uploaded files
UPLOAD_BASE_URL=http://localhost:3000/uploads

# ============================================================================
# EXTERNAL API KEYS & SERVICES
# ============================================================================

# Google Maps API Key (for embedded maps)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google reCAPTCHA keys (for form protection)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ============================================================================
# SOCIAL MEDIA & EXTERNAL LINKS
# ============================================================================

# Social media URLs
SOCIAL_FACEBOOK=https://facebook.com/jayashreefoundation
SOCIAL_TWITTER=https://twitter.com/jayashreefdn
SOCIAL_INSTAGRAM=https://www.instagram.com/jayashree_foundation
SOCIAL_LINKEDIN=https://linkedin.com/company/jayashree-foundation

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log level (error, warn, info, debug, trace)
LOG_LEVEL=info

# Enable debug mode (true/false)
DEBUG=false

# ============================================================================
# CORS & SECURITY HEADERS
# ============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://jayashreefoundation.org

# Enable CORS
CORS_ENABLED=true

# ============================================================================
# MONITORING & ANALYTICS (Optional)
# ============================================================================

# Google Analytics Tracking ID
GOOGLE_ANALYTICS_ID=

# Sentry DSN for error tracking
SENTRY_DSN=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
ENABLE_MAINTENANCE_MODE=false
ENABLE_NEWSLETTER=true
ENABLE_DONATIONS=false

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
#
# 1. NEVER commit the .env file to version control
# 2. Always use strong, unique values for secrets in production
# 3. Rotate secrets regularly
# 4. Keep this .env.example file updated with new variables
# 5. Never share the .env file with anyone
# 6. Use different values for development, staging, and production
# 7. For sensitive values:
#    - Generate new JWT_SECRET: Use a password generator
#    - Gmail App Password: Create in Google Account Security settings
#    - API Keys: Generate from respective service dashboards
#
# ============================================================================
